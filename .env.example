# RIK e-Financials API Credentials
# Copy this file to .env and fill in real values. NEVER commit .env.
#
# Get keys from e-Financials:
#   Settings > General settings > e-Financials API access permits
#
# Demo keys must be created in the DEMO environment — they are not
# interchangeable with production keys.

RIK_API_KEY_ID=your_api_key_id
RIK_API_KEY_PASSWORD=your_api_key_password
RIK_API_KEY_PUBLIC=your_base64_public_key

# Base URL — uncomment one:
# Production (default if omitted):
# RIK_API_BASE_URL=https://rmp-api.rik.ee
# Demo / training:
# RIK_API_BASE_URL=https://demo-rmp-api.rik.ee

# Optional HTTP retry (transient 5xx / 429 / 408 and network failures only; default 0 = off)
# RIK_HTTP_MAX_RETRIES=2
# RIK_HTTP_RETRY_BASE_MS=500

# Structured logs (stderr only; stdout is reserved for MCP)
# LOG_LEVEL=info
